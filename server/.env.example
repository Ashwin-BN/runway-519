# Server environment variables - copy to .env and fill values

# Node
NODE_ENV=production
PORT=5000
CLIENT_URL=https://your-client-domain.com

# MongoDB (include database name at the end)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/<database-name>

# Firebase Admin credentials (JSON string). In production set this env var instead of storing firebase-admin.json in repo.
# Example (escaped JSON):
# FIREBASE_ADMIN_CREDENTIALS={"type":"service_account", ...}

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional: additional settings
# LOG_LEVEL=info
