# Server environment variables - copy to .env and fill values

# Node
NODE_ENV=production
PORT=5000
CLIENT_URL=https://your-client-domain.com

# MongoDB (include database name at the end)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/<database-name>

# Firebase Admin credentials (JSON string). In production set this env var instead of storing firebase-admin.json in repo.
# Get the service account JSON from Firebase Console → Project Settings → Service Accounts → Generate new private key
# Paste the ENTIRE JSON as the value (it will be multi-line when pasted into Render/Vercel env vars)
FIREBASE_ADMIN_CREDENTIALS={"type":"service_account","project_id":"your-project-id","private_key_id":"your-private-key-id","private_key":"-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n","client_email":"your-service-account@your-project.iam.gserviceaccount.com","client_id":"your-client-id"}04803046","auth_uri": "https://accounts.google.com/o/oauth2/auth","token_uri": "https://oauth2.googleapis.com/token","auth_provider_x509_cert_url": "https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url": "https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk-fbsvc%40runway-519.iam.gserviceaccount.com","universe_domain": "googleapis.com"}


# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional: additional settings
# LOG_LEVEL=info
